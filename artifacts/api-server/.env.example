# ============================
# Backend (artifacts/api-server) - Node.js Environment Variables
# ============================

# Server port (required)
PORT=3001

# PostgreSQL connection string (required)
# Example for local: postgresql://user:password@localhost:5432/antuq
# Example for Google Cloud SQL: postgresql://user:password@/antuq?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgresql://...

# Clerk credentials (required)
# Get them from: https://dashboard.clerk.com/
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# OpenAI / OpenRouter configuration (required for AI stories)
OPENAI_API_KEY=sk-...
# Optional: override the default OpenRouter endpoint
OPENAI_BASE_URL=https://openrouter.ai/api/v1
# Optional: override the default model
OPENAI_MODEL=openai/gpt-4o-mini

# Google Cloud Storage / object storage (required for file uploads)
# Path prefixes to public buckets/directories, comma-separated.
# Example: /antuq-public-assets,/antuq-public-assets-v2
PUBLIC_OBJECT_SEARCH_PATHS=
# Private bucket/directory for user uploads.
# Example: /antuq-private-uploads
PRIVATE_OBJECT_DIR=

# Optional: Google Cloud project ID (used for GCS signed URLs and ADC)
GOOGLE_CLOUD_PROJECT_ID=
# Optional: path to service account key JSON (only if not using ADC on Cloud Run/GCE)
GOOGLE_APPLICATION_CREDENTIALS=

# Optional: Comma-separated list of allowed origins for CORS (e.g. https://antuq.app,https://www.antuq.app)
# If not set, CORS allows all origins (not recommended for production).
ALLOWED_ORIGINS=

# Optional: Pino log level (default: info)
LOG_LEVEL=info
