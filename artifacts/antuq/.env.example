# ============================
# Frontend (artifacts/antuq) - Vite Environment Variables
# ============================

# Clerk frontend publishable key (required)
# Get it from: https://dashboard.clerk.com/
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Optional: Clerk proxy URL (used in production for custom domains)
# Example: https://your-domain.com/api/__clerk
VITE_CLERK_PROXY_URL=

# Vite base path (used for artifact routing and Wouter base)
# For external hosting at root domain, use: /
# For subdirectory, use: /subdirectory/
BASE_PATH=/

# Dev server port (required by Vite config)
PORT=3000
